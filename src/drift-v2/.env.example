# Drift v2 — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Slack OAuth ──────────────────────────────────────────────────────────────
# From your Slack app dashboard → OAuth & Permissions
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Pre-configured incoming webhook URL (alternative to full OAuth flow)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Redis ─────────────────────────────────────────────────────────────────────
# Connection string for rate-limit and customer-webhook state
REDIS_URL=redis://localhost:6379/0

# ── API security ──────────────────────────────────────────────────────────────
# Secret key used to authenticate inbound webhook events (X-API-Key header)
DRIFT_API_SECRET=change-me-to-a-random-secret

# ── Free-tier tuning (optional overrides) ─────────────────────────────────────
# Max models per API key in the rolling window (default: 3)
# FREE_MODEL_LIMIT=3

# Rolling window length in days (default: 30)
# RATE_WINDOW_DAYS=30

# ── Webhook server ────────────────────────────────────────────────────────────
# Port for the Flask webhook receiver (default: 5050)
# WEBHOOKS_PORT=5050
