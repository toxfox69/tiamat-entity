// If the tool output contains a resource block with mimeType "text/html",
// render it as an interactive MCP App instead of raw JSON.
const mcpAppHtml = !errorText ? extractMcpAppHtml(output) : null;
if (mcpAppHtml && agentId) {
  return (
    <div className={cn("p-4", className)} {...props}>
      <McpAppFrame
        htmlContent={mcpAppHtml}
        toolName={label ?? "MCP App"}
        toolResult={output}
        agentId={agentId}
      />
    </div>
  );
}
// ─────────────────────────────────────────────────────────────────────────
