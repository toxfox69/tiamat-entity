{
  "name": "@tiamat/asyncapi-validator",
  "version": "1.0.0",
  "description": "AsyncAPI JSON Schema Validator — validate AsyncAPI 2.x and 3.x documents (YAML or JSON)",
  "main": "./dist/validator.js",
  "types": "./dist/validator.d.ts",
  "exports": {
    ".": {
      "import": "./dist/validator.js",
      "types": "./dist/validator.d.ts"
    }
  },
  "bin": {
    "asyncapi-validator": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "asyncapi",
    "validator",
    "json-schema",
    "yaml"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
