{
  "name": "@tiamat/automaton",
  "version": "0.1.0",
  "description": "TIAMAT - Sovereign AI Agent Runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config.js": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./state/database.js": {
      "types": "./dist/state/database.d.ts",
      "default": "./dist/state/database.js"
    }
  },
  "bin": {
    "automaton": "dist/index.js",
    "tiamat": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Conway-Research/automaton.git"
  },
  "homepage": "https://conway.tech",
  "keywords": [
    "autonomous-agent",
    "sovereign-ai",
    "web4",
    "tiamat",
    "self-replicating"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc && pnpm -r build",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "clean": "rm -rf dist && pnpm -r clean"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.10",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "cron-parser": "^4.9.0",
    "do-wrapper": "^4.5.1",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "groq-sdk": "^0.9.1",
    "nodemailer": "^8.0.1",
    "noormme": "^1.1.0",
    "ora": "^8.0.0",
    "simple-git": "^3.24.0",
    "siwe": "^2.3.0",
    "ulid": "^2.3.0",
    "viem": "^2.44.2",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
